PORT=3000
LISTEN_HOST=0.0.0.0
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/scriptcontrol?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
# Comma-separated browser origins (Vite dev server). Add your LAN IP:port for phones/other PCs.
# Production: add your deployed web app origin, e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173,http://192.168.1.100:5173
# If true, any http://192.168.x.x / 10.x / 172.16–31.x origin is allowed (dev convenience).
ALLOW_PRIVATE_LAN_CORS=true
